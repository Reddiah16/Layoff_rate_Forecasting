{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run FastAPI App",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["app:app", "--host", "127.0.0.1", "--port", "8000", "--reload"],
      "jinja": true,
      "justMyCode": true
    },
    {
      "name": "Train Random Forest",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/random_forest_model.py",
      "args": ["data/layoffs.csv"],
      "console": "integratedTerminal"
    },
    {
      "name": "Run ARIMA",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/arima_model.py",
      "args": ["data/layoffs.csv", "12"],
      "console": "integratedTerminal"
    }
  ]
}
