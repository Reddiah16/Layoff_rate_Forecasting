# LayoffLens — Environment Configuration
# Edit values here to change settings without touching Python code

# Random Forest
RF_N_ESTIMATORS=200
RF_MAX_DEPTH=20
RF_MIN_SAMPLES_SPLIT=5
RF_MIN_SAMPLES_LEAF=2
RF_MAX_FEATURES=sqrt
RF_POSITIVE_THRESHOLD=0.20

# ARIMA
ARIMA_AUTO_ORDER=true
ARIMA_P=1
ARIMA_D=1
ARIMA_Q=1
ARIMA_FORECAST_STEPS=12

# Training
TEST_SIZE=0.20
RANDOM_STATE=42
TIME_SERIES_FREQ=ME

# Risk Thresholds
RISK_LOW_MAX=0.10
RISK_MEDIUM_MAX=0.25
PRED_HIGH_PROB=0.70
PRED_MEDIUM_PROB=0.40

# Server
HOST=127.0.0.1
PORT=8000
